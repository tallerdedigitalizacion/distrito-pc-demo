---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { url } from '../utils/url';
import '../styles/global.css';

const categories = [
  {
    id: 'sobremesa',
    title: 'Ordenadores de Sobremesa',
    desc: 'Torres ATX y minitorre para el hogar, la oficina o el gaming. Equipos nuevos ensamblados con los mejores componentes o reacondicionados de calidad certificada.',
    items: ['PCs nuevos ensamblados a medida', 'Equipos reacondicionados con garantía', 'Minitorre y torre ATX', 'Configuraciones gaming y ofimática'],
  },
  {
    id: 'portatiles',
    title: 'Portátiles',
    desc: 'Desde gama media hasta portátiles profesionales. Asesoramiento personalizado para elegir el equipo que mejor se adapta a tus necesidades y presupuesto.',
    items: ['Portátiles nuevos y reacondicionados', 'Gama ofimática y profesional', 'Ultrabooks ligeros', 'Ampliaciones de RAM y SSD'],
  },
  {
    id: 'componentes',
    title: 'Componentes',
    desc: 'Mejora o amplía tu equipo con componentes de las mejores marcas. Procesadores Intel y AMD, placas base, tarjetas gráficas, memorias RAM y almacenamiento.',
    items: ['Procesadores Intel Core y AMD Ryzen', 'Placas base ASUS, MSI, Gigabyte', 'Tarjetas gráficas AMD y NVIDIA', 'Memorias RAM y SSD/HDD'],
  },
  {
    id: 'consumibles',
    title: 'Consumibles',
    desc: 'Cartuchos de tinta y tóneres originales y compatibles para todas las marcas de impresoras. Mejor precio garantizado y la misma calidad de impresión.',
    items: ['Cartuchos originales y compatibles', 'Tóneres para láser', 'Papel y accesorios de impresión', 'Todas las marcas: HP, Canon, Epson, Brother'],
  },
  {
    id: 'perifericos',
    title: 'Periféricos y Accesorios',
    desc: 'Ratones, teclados, auriculares, webcams, monitores y todo lo que necesitas para completar tu puesto de trabajo o equipo de entretenimiento.',
    items: ['Ratones y teclados', 'Auriculares y altavoces', 'Monitores y pantallas', 'Webcams, hubs USB y cables'],
  },
  {
    id: 'smartphones',
    title: 'Smartphones y Tablets',
    desc: 'Gama media y alta con asesoramiento profesional. Te ayudamos a elegir el smartphone o tablet que mejor se adapta a lo que necesitas.',
    items: ['Smartphones gama media-alta', 'Tablets Android e iPad', 'Fundas y protectores de pantalla', 'Asesoramiento personalizado'],
  },
];
---

<Layout
  title="Informática | Distrito PC — Tienda de informática en Fuensalida, Toledo"
  description="Venta de ordenadores, portátiles, componentes, consumibles y periféricos en Fuensalida (Toledo). Equipos nuevos y reacondicionados certificados."
  canonical="/informatica"
>
  <Header />
  <main>

    <section class="relative pt-32 pb-16 overflow-hidden" style="background: var(--dpc-surface);">
      <div class="absolute inset-0 bg-grid-orange opacity-50" style="background-size: 50px 50px;" aria-hidden="true"></div>
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at 10% 80%, rgba(255,82,0,0.1) 0%, transparent 50%);" aria-hidden="true"></div>
      <div class="section-container relative z-10">
        <nav class="flex items-center gap-2 text-dpc-muted mb-6" style="font-size: 0.82rem;">
          <a href={url('/')} class="hover:text-dpc-orange2 transition-colors">Inicio</a>
          <span>›</span>
          <span class="text-dpc-text">Informática</span>
        </nav>
        <div class="section-tag">Productos</div>
        <h1 class="font-heading font-bold" style="font-size: clamp(2.2rem, 5vw, 3.5rem); margin-top: 0.5rem;">
          Todo lo que<br /><span class="gradient-text">necesitas en tecnología.</span>
        </h1>
        <p class="text-dpc-muted mt-4" style="max-width: 540px; font-size: 1.05rem; line-height: 1.7;">
          Desde un simple ratón hasta un PC ensamblado a medida. Encuentra el producto adecuado con el asesoramiento de nuestro equipo.
        </p>
      </div>
    </section>

    <section class="py-16 md:py-24" style="background: var(--dpc-black);">
      <div class="section-container">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {categories.map((cat, i) => (
            <div id={cat.id} class="service-card reveal" style={`transition-delay: ${0.06 * i}s;`}>
              <h2 class="font-heading font-bold text-dpc-text" style="font-size: 1.4rem; margin-bottom: 0.7rem;">{cat.title}</h2>
              <p class="text-dpc-muted" style="font-size: 0.92rem; line-height: 1.65; margin-bottom: 1.2rem;">{cat.desc}</p>
              <ul class="flex flex-col gap-1.5">
                {cat.items.map((item) => (
                  <li class="flex items-start gap-2 text-dpc-muted" style="font-size: 0.88rem;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-dpc-orange flex-shrink-0 mt-0.5"><path d="M20 6L9 17l-5-5"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <div class="mt-16 rounded-xl p-8 reveal text-center" style="background: var(--dpc-surface); border: 1px solid var(--dpc-border);">
          <h3 class="font-heading font-bold text-dpc-text" style="font-size: 1.6rem; margin-bottom: 0.8rem;">¿No encuentras lo que buscas?</h3>
          <p class="text-dpc-muted" style="max-width: 460px; margin: 0 auto 1.5rem; font-size: 0.95rem;">
            Consúltanos sin compromiso. Gestionamos pedidos especiales y te asesoramos sobre la mejor opción para tu presupuesto.
          </p>
          <a href={url('/contacto')} class="btn-primary"><span>Consultar disponibilidad</span></a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <WhatsAppButton />
</Layout>
