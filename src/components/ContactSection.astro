---
import { url } from '../utils/url';
---
<section
  id="contacto-cta"
  class="py-20 md:py-28 relative overflow-hidden"
  style="background: var(--dpc-black);"
>
  <div
    class="absolute inset-0 bg-grid-orange opacity-60"
    style="background-size: 50px 50px;"
    aria-hidden="true"
  ></div>
  <div
    class="absolute inset-0"
    style="background: radial-gradient(ellipse at 50% 100%, rgba(255,82,0,0.12) 0%, transparent 60%);"
    aria-hidden="true"
  ></div>

  <div class="section-container relative z-10">
    <div
      class="max-w-3xl mx-auto text-center reveal"
      style="
        background: var(--dpc-surface);
        border: 1px solid #28283c;
        border-radius: 16px;
        padding: clamp(2rem, 5vw, 4rem);
        box-shadow: 0 0 0 1px rgba(255,82,0,0.08), 0 20px 60px rgba(0,0,0,0.5);
      "
    >
      <div class="section-tag" style="display: inline-flex; margin-bottom: 1.2rem;">Contacto</div>

      <h2
        class="font-heading font-bold"
        style="font-size: clamp(1.9rem, 4vw, 2.8rem); margin-bottom: 1rem;"
      >
        ¿Tienes algún problema<br />
        <span class="gradient-text">con tu equipo?</span>
      </h2>
      <p
        class="text-dpc-muted"
        style="font-size: 1rem; max-width: 480px; margin: 0 auto 2rem; line-height: 1.7;"
      >
        Llámanos, escríbenos por WhatsApp o pásate por la tienda.
        Estamos en C/ Juan de Ávila 4, local 2 · Fuensalida (Toledo).
      </p>

      <div class="flex flex-wrap justify-center gap-4">
        <a href="tel:925733019" class="btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          <span>925 73 30 19</span>
        </a>
        <a href={url('/contacto')} class="btn-secondary">
          Formulario de contacto
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <div
        class="flex flex-wrap justify-center gap-x-8 gap-y-3 mt-8 pt-8"
        style="border-top: 1px solid var(--dpc-border);"
      >
        {[
          { icon: '📍', text: 'Fuensalida, Toledo' },
          { icon: '📱', text: '667 51 52 07' },
          { icon: '✉️', text: 'consulta@distritopc.com' },
        ].map((item) => (
          <div class="flex items-center gap-2 text-dpc-muted" style="font-size: 0.88rem;">
            <span>{item.icon}</span>
            <span>{item.text}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
