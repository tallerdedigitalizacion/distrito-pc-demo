# Astro environment variables
# Copy to .env and fill in the real API URL after deploying the CDK stack.

# URL of the API Gateway endpoint created by the CDK ContactStack.
# Get it from the CloudFormation output "ContactApiUrl" after running:
#   cd infrastructure && npm run deploy
PUBLIC_CONTACT_API_URL=https://xxxxxxxxxx.execute-api.eu-west-1.amazonaws.com/contact
